medtype:Procedure a owl:Class ;
    rdfs:label "Procedure" ;
    skos:altLabel "ExaminationProcedure",
        "ImagingProcedure",
        "LaboratoryProcedure" ;
    skos:definition "Any procedural information" ;
    skos:prefLabel "Procedure" .

medtype:Disease a owl:Class ;
    rdfs:label "Disease" ;
    skos:definition "Pathological or medical condition identified" ;
    skos:prefLabel "Disease" .

medtype:Finding a owl:Class ;
    rdfs:label "Finding" ;
