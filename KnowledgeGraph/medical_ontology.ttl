@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix med: <http://example.org/medical/> .
@prefix medtype: <http://example.org/medical/types/> .

# ========================================
# TYPE DEFINITIONS (5 categories only)
# ========================================

medtype:Finding a owl:Class ;
    rdfs:label "Finding" ;
    skos:prefLabel "Finding" ;
    skos:definition "Clinical observation described in a report (e.g., fever, coughing, back pain)" .

medtype:Disease a owl:Class ;
    rdfs:label "Disease" ;
    skos:prefLabel "Disease" ;
    skos:definition "Pathological or medical condition identified" .

medtype:QuantitativeMeasure a owl:Class ;
    rdfs:label "QuantitativeMeasure" ;
    skos:prefLabel "Quantitative Measure" ;
    skos:altLabel "Parameter" ;
    skos:altLabel "ExaminationMeasure" ;
    skos:definition "Quantitative measurement recorded" .

medtype:Substance a owl:Class ;
    rdfs:label "Substance" ;
    skos:prefLabel "Substance" ;
    skos:altLabel "Medication" ;
    skos:altLabel "Drug" ;
    skos:definition "Material administered or detected" .

medtype:Procedure a owl:Class ;
    rdfs:label "Procedure" ;
    skos:prefLabel "Procedure" ;
    skos:altLabel "ExaminationProcedure" ;
    skos:altLabel "ImagingProcedure" ;
    skos:altLabel "LaboratoryProcedure" ;
    skos:definition "Any procedural information" .

